{
  "name": "modmarket-launcher-frontend",
  "productName": "ModMarket Launcher",
  "description": "ModMarket Launcher v2 desktop application",
  "author": "Prem",
  "private": true,
  "version": "2.0.0",
  "main": "build-electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "build:all": "npm run build && npm run build:electron",
    "preview": "vite preview",
    "clean": "rm -rf dist build-electron",
    "lint": "tsc --noEmit",
    "electron:build": "npm run build:all && electron-builder",
    "electron:dev": "concurrently -k \"vite --port=3000 --host=0.0.0.0\" \"wait-on http://localhost:3000 && node scripts/build-electron.mjs && npx electron .\""
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "express": "^4.21.2",
    "dotenv": "^17.2.3",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.0.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.modmarket.launcher",
    "productName": "ModMarket Launcher",
    "files": [
      "dist/**/*",
      "build-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "build-electron/main.cjs"
    },
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "sign": false,
      "signAndEditExecutable": false
    }
  }
}
